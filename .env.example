# QuestLearn 환경변수 예시
# 이 파일을 복사해 .env.local 을 만들고 실제 값으로 채우세요. (.env.local 은 git에 올라가지 않습니다)

# --- Anthropic (Claude API) ---
# https://console.anthropic.com 에서 API 키 발급
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# Supabase 프로젝트 > Settings > API 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role 키 (서버 전용 · 절대 프론트엔드에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
