# QuestLearn 환경변수 예시
# 이 파일을 복사해 .env.local 을 만들고 실제 값으로 채우세요. (.env.local 은 git에 올라가지 않습니다)

# --- Supabase (로그인 + DB) ---
# Supabase 프로젝트 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# anon(publishable) 키 — 공개되어도 되는 키 (RLS가 데이터를 보호)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# --- (선택) Anthropic (Claude API) ---
# 키가 없으면 데모(목업) 모드로 동작합니다. 실제 AI를 쓰려면 발급 후 넣으세요.
# https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
